# local keeps files in public/mangas. Use s3 in production on EC2.
STORAGE_DRIVER=local

# Required when STORAGE_DRIVER=s3.
AWS_REGION=us-east-1
S3_BUCKET=your-manga-reader-bucket

# Optional prefix inside the bucket, useful if sharing a bucket.
S3_PREFIX=

# Optional. If empty, S3 files are served through /api/files/... using the EC2 IAM role.
# Set this to a CloudFront domain if you later put CloudFront in front of S3.
S3_PUBLIC_BASE_URL=
